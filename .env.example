# =============================================================================
# Environment Variables — Copy this file to .env.local and fill in values
# =============================================================================

APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL — optional fallback if APP_URL is not set
# NEXT_PUBLIC_APP_URL="https://hass-quality-properties.vercel.app"

# --- Neon (PostgreSQL) ---
# Get FROM: https://console.neon.tech -> Project -> Connection Details
# Use the pooled connection string (includes -pooler) for serverless
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Clerk (Authentication) ---
# Get from: https://dashboard.clerk.com -> Application -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/admin/login"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/admin"

# --- Admin Access ---
# Comma-separated list of email addresses allowed to access admin
ADMIN_EMAILS="admin@example.com"

# --- Cloudflare R2 (Image / Video Storage) ---
# Get from: https://dashboard.cloudflare.com -> R2 -> Bucket -> Settings
R2_ACCOUNT_ID="your_account_id"                              # From R2 overview page
R2_ACCESS_KEY_ID="your_access_key_id"                        # Create API token in R2
R2_SECRET_ACCESS_KEY="your_secret_access_key"                 # Shown once when token created
R2_BUCKET_NAME="hass-properties"                             # Your bucket name
R2_PUBLIC_URL="https://pub-xxx.r2.dev"                       # Public bucket URL (enable public access in R2)

# --- Resend (Email Notifications) ---
# Optional. Get from: https://resend.com/api-keys
# Used to send email alerts when visitors submit the contact form or request inspections
# RESEND_API_KEY="re_..."

# --- Bing IndexNow ---
# Optional. Get from: https://www.bing.com/indexnow/getstarted
# Used to instantly notify Bing about content changes
# INDEXNOW_KEY="your-indexnow-key"
