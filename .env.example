# =============================================================================
# Environment Variables.
# =============================================================================

APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL — optional fallback if APP_URL is not set
# NEXT_PUBLIC_APP_URL="https://hassproperties.online"

# --- Neon (PostgreSQL) ---
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Supabase (Authentication) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Admin Access ---
ADMIN_EMAILS="admin@example.com"

# --- Cloudflare R2 (Image / Video Storage) ---
R2_ACCOUNT_ID="your_account_id"                             
R2_ACCESS_KEY_ID="your_access_key_id"                      
R2_SECRET_ACCESS_KEY="your_secret_access_key"            
R2_BUCKET_NAME="hass-properties"                         
R2_PUBLIC_URL="https://pub-xxx.r2.dev"                   

# --- Resend (Email Notifications) ---
# Used to send email alerts when visitors submit the contact form or request inspections
# RESEND_API_KEY="re_..."

# --- Bing IndexNow ---
# Used to instantly notify Bing about content changes
# INDEXNOW_KEY="your-indexnow-key"

# --- Google Search Console ---
# GOOGLE_SITE_VERIFICATION="your-verification-code"
